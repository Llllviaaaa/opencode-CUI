        <mxCell id="c1o" value="POST /api/skill/sessions/{id}&#xa;     /permissions/{permissionId}&#xa;{&#xa;  &quot;response&quot;: &quot;always&quot;,&#xa;  &quot;subagentSessionId&quot;: null&#xa;}" style="shape=note;size=15;fillColor=#e8f5e9;strokeColor=#2D7600;fontSize=10;fontFamily=Courier New;align=left;spacingLeft=8;spacingTop=5;whiteSpace=wrap;" vertex="1" parent="1">
